{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "installDir": "${sourceDir}/install/${presetName}",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "external/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "CXX_STANDARD": "20",
        "CXX_STANDARD_REQUIRED": true,
        "CMAKE_EXPORT_COMPILE_COMMANDS": true,
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "VCPKG_FEATURE_FLAGS": "manifests"
      }
    },
    {
      "name": "windows-base",
      "hidden": true,
      "inherits": "base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "win-deb",
      "displayName": "Windows Debug",
      "inherits": "windows-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "win-rel",
      "displayName": "Windows Release",
      "inherits": "windows-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "base-deb",
      "configurePreset": "win-deb",
      "configuration": "Debug",
      "verbose": true,
      "hidden": true
    },
    {
      "name": "all-win-deb",
      "displayName": "Build everything for Windows debug",
      "inherits": "base-deb"
    },
    {
      "name": "all-win-rel",
      "displayName": "Build everything for Windows release",
      "configurePreset": "win-rel"
    },
    {
      "name": "build-engine-deb",
      "inherits": "base-deb",
      "targets": [
        "Engine",
        "EngineTest"
      ]
    },
    {
      "name": "install-engine-deb",
      "inherits": "base-deb",
      "targets": [
        "InstallEngine"
      ]
    },
    {
      "name": "build-chess-deb",
      "inherits": "base-deb",
      "targets": [
        "BoredChess"
      ]
    }
  ],
  "testPresets": [
    {
      "name": "test-engine-deb",
      "configurePreset": "win-deb",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error",
        "stopOnFailure": false
      },
      "filter": {
        "include": {
          "name": "^BoredEngine::"
        }
      }
    },
    {
      "name": "test-chess",
      "configurePreset": "win-deb",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "stopOnFailure": false
      },
      "filter": {
        "include": {
          "name": "^BoredChess::"
        }
      }
    }
  ],
  "workflowPresets": [
    {
      "name": "engine-deb",
      "displayName": "Build, install, and test engine for debug",
      "steps": [
        {
          "type": "configure",
          "name": "win-deb"
        },
        {
          "type": "build",
          "name": "build-engine-deb"
        },
        {
          "type": "build",
          "name": "install-engine-deb"
        },
        {
          "type": "test",
          "name": "test-engine-deb"
        }
      ]
    },
    {
      "name": "chess-deb",
      "displayName": "Build and test chess",
      "steps": [
        {
          "type": "configure",
          "name": "win-deb"
        },
        {
          "type": "build",
          "name": "build-chess-deb"
        },
        {
          "type": "test",
          "name": "test-chess"
        }
      ]
    }
  ]
}
